#!/usr/bin/env bash

DIR="${JIRA_DIR:-$HOME/.jirasik}"
CONFIG="$DIR/config"

if [[ ! -f "$CONFIG" ]]; then
  gum style --foreground="#ff0000" "No config found"
  gum style "Run: git clone ... && ./setup.sh"
  exit 1
fi

source "$CONFIG"
source "$DIR/scripts/auth.sh"

show_help() {
  echo "Usage: jirasik [COMMAND] [OPTIONS]"
  echo ""
  echo "Commands:"
  echo "  jirasik               Interactive menu (default)"
  echo "  jirasik <TICKET>      Fetch ticket (e.g., jirasik PROG-123)"
  echo "  jirasik -t, --todos   View Sprint Todos"
  echo "  jirasik -s, --sprint  View Sprint"
  echo "  jirasik -f, --fetch <TICKET>  Fetch specific ticket"
  echo "  jirasik -m, --move <TICKET> [STATUS]  Move ticket"
  echo "  jirasik -c, --comments <TICKET>       View comments"
  echo "  jirasik -a, --add-comment <TICKET> [TEXT]  Add comment"
  echo "  jirasik -w, --wiki <URL|PAGE-ID>      Fetch Confluence page"
  echo "  jirasik -p, --points  Sprint Points"
  echo "  jirasik -P, --add-project [DIR]  Register current/provided dir as a project"
  echo "  jirasik -R, --remove-project [DIR]  Unregister a project"
  echo "  jirasik -u, --update  Update jirasik (pull + refresh install)"
  echo "  jirasik -o, --open    Open Jira in Browser"
  echo "  jirasik -h, --help    Show this help"
  echo ""
  echo "Options:"
  echo "  -n, --no-banner       Suppress the banner"
  echo ""
  echo "Examples:"
  echo "  jirasik PROG-123          Fetch ticket directly"
  echo "  jirasik -m PROG-123       Move ticket (interactive)"
  echo '  jirasik -m PROG-123 "In Progress"  Move to specific status'
  echo "  jirasik -c PROG-123       View comments"
  echo "  jirasik -a PROG-123 \"Done\"  Add a comment"
  echo "  jirasik -t -n             Quick todos without banner"
}

TICKET_REGEX='^[A-Z]+-[0-9]+$'
is_ticket() {
  [[ "$1" =~ $TICKET_REGEX ]]
}

# Fetch a Confluence page and render it as paged markdown.
# The script emits metadata lines (Title:, Space:, ...), a blank line, then
# Confluence storage-format XHTML. We split on the first blank line, convert
# the XHTML body to markdown, prepend the metadata as a header, and pipe the
# whole thing through glow -p for rendering + scrolling.
render_confluence() {
  local arg="$1" output rc
  output=$("$DIR/scripts/fetch_confluence.sh" "$arg")
  rc=$?
  if [[ $rc -ne 0 ]]; then
    printf '%s\n' "$output"
    return $rc
  fi

  # If pandoc or glow are missing, or stdout isn't a TTY, just pass through raw.
  if ! command -v pandoc &>/dev/null || ! command -v glow &>/dev/null || [[ ! -t 1 ]]; then
    printf '%s\n' "$output"
    return 0
  fi

  local header body
  header=$(printf '%s\n' "$output" | awk 'NF==0 {exit} {print}')
  body=$(printf '%s\n' "$output" | awk 'found {print} !found && NF==0 {found=1}')

  # Build markdown header from "Key: value" metadata lines.
  local md_header=""
  local title space version modified url
  title=$(printf '%s\n' "$header" | sed -n 's/^Title: //p')
  space=$(printf '%s\n' "$header" | sed -n 's/^Space: //p')
  version=$(printf '%s\n' "$header" | sed -n 's/^Version: //p')
  modified=$(printf '%s\n' "$header" | sed -n 's/^Modified: //p')
  url=$(printf '%s\n' "$header" | sed -n 's/^URL: //p')
  [[ -n "$title" ]] && md_header+="# ${title}"$'\n\n'
  [[ -n "$space" ]]    && md_header+="- **Space:** ${space}"$'\n'
  [[ -n "$version" ]]  && md_header+="- **Version:** ${version}"$'\n'
  [[ -n "$modified" ]] && md_header+="- **Modified:** ${modified}"$'\n'
  [[ -n "$url" ]]      && md_header+="- **URL:** <${url}>"$'\n'
  md_header+=$'\n---\n\n'

  # Pre-process Confluence-specific XHTML so pandoc can handle it.
  #   ac:structured-macro name="code" -> fenced code block
  #   ac:structured-macro name="info|note|warning|tip" -> blockquote
  #   strip ac:local-id / local-id attrs pandoc doesn't care about
  local cleaned md
  cleaned=$(printf '%s' "$body" | perl -0777 -pe '
    # Code macro: <ac:structured-macro ac:name="code"> ... <ac:parameter ac:name="language">LANG</ac:parameter> ... <ac:plain-text-body>CODE</ac:plain-text-body> ... </ac:structured-macro>
    s{<ac:structured-macro[^>]*ac:name="code"[^>]*>(.*?)</ac:structured-macro>}{
      my $inner = $1;
      my ($lang) = $inner =~ m{<ac:parameter[^>]*ac:name="language"[^>]*>([^<]*)</ac:parameter>};
      my ($code) = $inner =~ m{<ac:plain-text-body[^>]*>(.*?)</ac:plain-text-body>}s;
      $code //= "";
      $lang //= "";
      "<pre><code class=\"language-$lang\">$code</code></pre>"
    }gsex;
    # Info / note / warning / tip panels -> blockquote
    s{<ac:structured-macro[^>]*ac:name="(info|note|warning|tip)"[^>]*>(.*?)</ac:structured-macro>}{<blockquote>$2</blockquote>}gs;
    # Drop any remaining ac:* macros (unknown) by unwrapping rich-text-body if present
    s{<ac:rich-text-body[^>]*>(.*?)</ac:rich-text-body>}{$1}gs;
    s{<ac:structured-macro[^>]*>(.*?)</ac:structured-macro>}{$1}gs;
    # Strip ac:*/local-id attrs and self-closing ac:* tags
    s{\s(ac:[a-z-]+|local-id)="[^"]*"}{}g;
    s{<ac:[^/>]*/>}{}g;
  ')

  md=$(printf '%s' "$cleaned" | pandoc -f html -t gfm --wrap=none 2>/dev/null || printf '%s' "$cleaned")
  printf '%s%s' "$md_header" "$md" | glow -p -
}

# --- Project management (used by --add-project) ---

PROJECTS_FILE="$DIR/projects"

_jirasik_repo_root() {
  cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd
}

_jirasik_project_exists() {
  local dir="$1"
  [[ -f "$PROJECTS_FILE" ]] || return 1
  grep -qxF "$dir" "$PROJECTS_FILE" 2>/dev/null
}

_jirasik_install_to_project() {
  local project_dir="$1"
  local jira_url="${2:-}"
  local repo; repo="$(_jirasik_repo_root)"
  local commands_dir="${project_dir%/}/.opencode/commands"
  local agents_dir="${project_dir%/}/.opencode/agents"
  local skills_dir="${project_dir%/}/.opencode/skills"
  mkdir -p "$commands_dir" "$agents_dir" "$skills_dir"

  for src in "$repo"/commands/*.md; do
    [[ -f "$src" ]] || continue
    local name; name=$(basename "$src")
    if grep -q '__JIRA_URL__' "$src"; then
      sed "s|__JIRA_URL__|$jira_url|g" "$src" > "$commands_dir/$name"
    else
      cp "$src" "$commands_dir/$name"
    fi
  done

  for src in "$repo"/agents/*.md; do
    [[ -f "$src" ]] || continue
    cp "$src" "$agents_dir/$(basename "$src")"
  done

  for src in "$repo"/skills/*.md; do
    [[ -f "$src" ]] || continue
    local skill_name="${src##*/}"
    skill_name="${skill_name%.md}"
    local skill_subdir="$skills_dir/$skill_name"
    mkdir -p "$skill_subdir"
    cp "$src" "$skill_subdir/SKILL.md"
  done
}

NO_BANNER=false

if [[ $# -eq 0 ]]; then
  MODE=interactive
else
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        show_help
        exit 0
        ;;
      -n|--no-banner)
        NO_BANNER=true
        shift
        ;;
      -t|--todos)
        MODE=todos
        shift
        ;;
      -s|--sprint)
        MODE=sprint
        shift
        ;;
      -f|--fetch)
        if [[ -z "${2:-}" ]]; then
          echo "Error: -f/--fetch requires a ticket argument"
          exit 1
        fi
        TICKET="$2"
        MODE=fetch
        shift 2
        ;;
      -m|--move)
        if [[ -z "${2:-}" ]]; then
          echo "Error: -m/--move requires a ticket argument"
          exit 1
        fi
        TICKET="$2"
        TRANSITION="${3:-}"
        if [[ -n "${3:-}" ]]; then
          shift 3
        else
          shift 2
        fi
        MODE=move
        ;;
      -c|--comments)
        if [[ -z "${2:-}" ]]; then
          echo "Error: -c/--comments requires a ticket argument"
          exit 1
        fi
        TICKET="$2"
        MODE=comments
        shift 2
        ;;
      -a|--add-comment)
        if [[ -z "${2:-}" ]]; then
          echo "Error: -a/--add-comment requires a ticket argument"
          exit 1
        fi
        TICKET="$2"
        COMMENT_TEXT="${3:-}"
        if [[ -n "${3:-}" ]]; then
          shift 3
        else
          shift 2
        fi
        MODE=add_comment
        ;;
      -w|--wiki)
        if [[ -z "${2:-}" ]]; then
          echo "Error: -w/--wiki requires a URL or page ID argument"
          exit 1
        fi
        CONFLUENCE_ARG="$2"
        MODE=confluence
        shift 2
        ;;
      -p|--points)
        MODE=points
        shift
        ;;
      -P|--add-project)
        ADD_PROJECT_DIR="${2:-}"
        if [[ -n "$ADD_PROJECT_DIR" ]] && [[ ! "$ADD_PROJECT_DIR" =~ ^- ]]; then
          shift 2
        else
          ADD_PROJECT_DIR="$(pwd)"
          shift
        fi
        MODE=add_project
        ;;
      -R|--remove-project)
        REMOVE_PROJECT_DIR="${2:-}"
        if [[ -n "$REMOVE_PROJECT_DIR" ]] && [[ ! "$REMOVE_PROJECT_DIR" =~ ^- ]]; then
          shift 2
        else
          REMOVE_PROJECT_DIR="$(pwd)"
          shift
        fi
        MODE=remove_project
        ;;
      -u|--update)
        MODE=update
        shift
        ;;
      -o|--open)
        MODE=open
        shift
        ;;
      *)
        if is_ticket "$1"; then
          TICKET="$1"
          MODE=fetch
          shift
        else
          echo "Error: Unknown argument '$1'"
          echo "Run 'jirasik --help' for usage"
          exit 1
        fi
        ;;
    esac
  done
fi

if [[ "$NO_BANNER" == "false" ]]; then
  LOGO='       ▄█ ▄█ ▄██████▄  ▄█████▄  ▄███████ ▄█ ▄████▀
       ██ ██ ██▄▄  ██ ██   ██ ██▄        ████▀
       ██ ██ ██████▀  ███████ ▀██████ ██ ████▄
  ██   ██ ██ ██  ▀█▄ ██   ██      ██ ██ ██ ▀██
   ▀████▀ ██ ██   ▀████   ██ ███████ ██ ██  ▀██▄'
  echo ""
  if command -v lolcat &>/dev/null; then
    echo "$LOGO" | lolcat -f -t -S 95 -p 4.0 -F 0.15
  else
    local_i=0
    while IFS= read -r line; do
      case $local_i in
        0) printf '\033[38;2;255;107;157m%s\033[0m\n' "$line" ;;
        1) printf '\033[38;2;196;77;255m%s\033[0m\n' "$line" ;;
        2) printf '\033[38;2;108;92;231m%s\033[0m\n' "$line" ;;
        3) printf '\033[38;2;9;132;227m%s\033[0m\n' "$line" ;;
        4) printf '\033[38;2;0;206;201m%s\033[0m\n' "$line" ;;
      esac
      local_i=$((local_i + 1))
    done <<< "$LOGO"
  fi
  gum style --faint --align center --width 50 "never look at jira again"
  echo ""
fi

case "${MODE:-}" in
  interactive)
    CHOICE=$(gum choose \
      "View Sprint Todos" \
      "View Sprint" \
      "Fetch Ticket" \
      "Move Ticket" \
      "View Comments" \
      "Add Comment" \
      "Fetch Confluence Page" \
      "Sprint Points" \
      "Open Jira in Browser" \
      "Update jirasik" \
      "Quit")

    case "$CHOICE" in
      "Fetch Ticket")
        TICKET=$(gum input --prompt "Ticket: ")
        if [[ -n "$TICKET" ]]; then
          echo ""
          "$DIR/scripts/fetch_ticket.sh" "$TICKET"
        fi
        ;;
      "View Sprint Todos")
        echo ""
        "$DIR/scripts/fetch_todos.sh"
        ;;
      "View Sprint")
        "$DIR/scripts/sprint-view.sh"
        ;;
      "Move Ticket")
        TICKET=$(gum input --prompt "Ticket: ")
        if [[ -n "$TICKET" ]]; then
          "$DIR/scripts/transition.sh" "$TICKET"
        fi
        ;;
      "View Comments")
        TICKET=$(gum input --prompt "Ticket: ")
        if [[ -n "$TICKET" ]]; then
          "$DIR/scripts/comments.sh" "$TICKET"
        fi
        ;;
      "Add Comment")
        TICKET=$(gum input --prompt "Ticket: ")
        if [[ -n "$TICKET" ]]; then
          "$DIR/scripts/add_comment.sh" "$TICKET"
        fi
        ;;
      "Fetch Confluence Page")
        CONFLUENCE_ARG=$(gum input --prompt "Confluence URL or Page ID: ")
        if [[ -n "$CONFLUENCE_ARG" ]]; then
          echo ""
          render_confluence "$CONFLUENCE_ARG"
        fi
        ;;
      "Sprint Points")
        echo ""
        "$DIR/scripts/points.sh"
        ;;
      "Open Jira in Browser")
        if [[ -n "${JIRA_URL:-}" ]]; then
          _ff_open_profile "$PROFILE_DIR" "$JIRA_URL"
        else
          gum style --foreground=1 "JIRA_URL not set"
        fi
        ;;
      "Update jirasik")
        UPDATE_BIN="$(dirname "${BASH_SOURCE[0]}")/jirasik-update"
        if [[ -x "$UPDATE_BIN" ]]; then
          exec "$UPDATE_BIN"
        else
          echo "Error: jirasik-update not found" >&2
        fi
        ;;
      "Quit")
        exit 0
        ;;
    esac
    ;;
  todos)
    echo ""
    "$DIR/scripts/fetch_todos.sh"
    ;;
  sprint)
    "$DIR/scripts/sprint-view.sh"
    ;;
  fetch)
    echo ""
    "$DIR/scripts/fetch_ticket.sh" "$TICKET"
    ;;
  move)
    if [[ -n "${TRANSITION:-}" ]]; then
      "$DIR/scripts/transition.sh" "$TICKET" "$TRANSITION"
    else
      "$DIR/scripts/transition.sh" "$TICKET"
    fi
    ;;
  comments)
    "$DIR/scripts/comments.sh" "$TICKET"
    ;;
  add_comment)
    if [[ -n "${COMMENT_TEXT:-}" ]]; then
      "$DIR/scripts/add_comment.sh" "$TICKET" "$COMMENT_TEXT"
    else
      "$DIR/scripts/add_comment.sh" "$TICKET"
    fi
    ;;
  confluence)
    echo ""
    render_confluence "$CONFLUENCE_ARG"
    ;;
  points)
    echo ""
    "$DIR/scripts/points.sh"
    ;;
  update)
    UPDATE_BIN="$(dirname "${BASH_SOURCE[0]}")/jirasik-update"
    if [[ -x "$UPDATE_BIN" ]]; then
      exec "$UPDATE_BIN"
    else
      echo "Error: jirasik-update not found at $UPDATE_BIN" >&2
      echo "Re-run setup.sh to install it." >&2
      exit 1
    fi
    ;;
  add_project)
    if [[ ! -d "$ADD_PROJECT_DIR" ]]; then
      gum style --foreground=1 "Error: directory does not exist: $ADD_PROJECT_DIR"
      exit 1
    fi
    ADD_PROJECT_DIR="$(cd "$ADD_PROJECT_DIR" && pwd)"
    if _jirasik_project_exists "$ADD_PROJECT_DIR"; then
      gum style --foreground=3 "Project already registered: $ADD_PROJECT_DIR"
    else
      mkdir -p "$(dirname "$PROJECTS_FILE")"
      echo "$ADD_PROJECT_DIR" >> "$PROJECTS_FILE"
      _jirasik_install_to_project "$ADD_PROJECT_DIR" "${JIRA_URL:-}"
      gum style --foreground=2 "✓ Registered project: $ADD_PROJECT_DIR"
      gum style --foreground=8 "  Commands/agents/skills installed to .opencode/"
    fi
    ;;
  remove_project)
    if [[ ! -d "$REMOVE_PROJECT_DIR" ]]; then
      gum style --foreground=1 "Error: directory does not exist: $REMOVE_PROJECT_DIR"
      exit 1
    fi
    REMOVE_PROJECT_DIR="$(cd "$REMOVE_PROJECT_DIR" && pwd)"
    if ! _jirasik_project_exists "$REMOVE_PROJECT_DIR"; then
      gum style --foreground=3 "Project not registered: $REMOVE_PROJECT_DIR"
    else
      grep -vxF "$REMOVE_PROJECT_DIR" "$PROJECTS_FILE" > "${PROJECTS_FILE}.tmp" && mv "${PROJECTS_FILE}.tmp" "$PROJECTS_FILE"
      gum style --foreground=2 "✓ Removed project: $REMOVE_PROJECT_DIR"
    fi
    ;;
  open)
    if [[ -n "${JIRA_URL:-}" ]]; then
      _ff_open_profile "$PROFILE_DIR" "$JIRA_URL"
    else
      gum style --foreground=1 "JIRA_URL not set"
    fi
    ;;
esac
