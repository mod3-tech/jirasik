#!/usr/bin/env bash

DIR="${JIRA_DIR:-$HOME/.firefox-mcp-jira}"
CONFIG="$DIR/config"

if [[ ! -f "$CONFIG" ]]; then
  gum style --foreground="#ff0000" "No config found"
  gum style "Run: git clone ... && ./setup.sh"
  exit 1
fi

source "$CONFIG"

# --- Banner ---
LOGO='       ‚ĖĄ‚Ėą ‚ĖĄ‚Ėą ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĄ  ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĄ  ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚ĖĄ‚Ėą ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėą‚ĖÄ
       ‚Ėą‚Ėą ‚Ėą‚Ėą ‚Ėą‚Ėą‚ĖĄ‚ĖĄ  ‚Ėą‚Ėą ‚Ėą‚Ėą   ‚Ėą‚Ėą ‚Ėą‚Ėą‚ĖĄ        ‚Ėą‚Ėą‚Ėą‚Ėą‚ĖÄ
       ‚Ėą‚Ėą ‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ĖÄ  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚ĖÄ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĄ
  ‚Ėą‚Ėą   ‚Ėą‚Ėą ‚Ėą‚Ėą ‚Ėą‚Ėą  ‚ĖÄ‚Ėą‚ĖĄ ‚Ėą‚Ėą   ‚Ėą‚Ėą      ‚Ėą‚Ėą ‚Ėą‚Ėą ‚Ėą‚Ėą ‚ĖÄ‚Ėą‚Ėą
   ‚ĖÄ‚Ėą‚Ėą‚Ėą‚Ėą‚ĖÄ ‚Ėą‚Ėą ‚Ėą‚Ėą   ‚ĖÄ‚Ėą‚Ėą‚Ėą‚Ėą   ‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą ‚Ėą‚Ėą  ‚ĖÄ‚Ėą‚Ėą‚ĖĄ'
echo ""
if command -v lolcat &>/dev/null; then
  echo "$LOGO" | lolcat -f -t -S 95 -p 4.0 -F 0.15
else
  local_i=0
  while IFS= read -r line; do
    case $local_i in
      0) printf '\033[38;2;255;107;157m%s\033[0m\n' "$line" ;;
      1) printf '\033[38;2;196;77;255m%s\033[0m\n' "$line" ;;
      2) printf '\033[38;2;108;92;231m%s\033[0m\n' "$line" ;;
      3) printf '\033[38;2;9;132;227m%s\033[0m\n' "$line" ;;
      4) printf '\033[38;2;0;206;201m%s\033[0m\n' "$line" ;;
    esac
    local_i=$((local_i + 1))
  done <<< "$LOGO"
fi
gum style --faint --align center --width 50 "never look at jira again"
echo ""

CHOICE=$(gum choose \
  "View Sprint Todos" \
  "View Sprint" \
  "Fetch Ticket" \
  "Move Ticket" \
  "Sprint Points" \
  "Open Jira in Browser" \
  "Quit")

case "$CHOICE" in
  "Fetch Ticket")
    TICKET=$(gum input --prompt "Ticket: ")
    if [[ -n "$TICKET" ]]; then
      echo ""
      "$DIR/fetch_ticket.sh" "$TICKET"
    fi
    ;;
  "View Sprint Todos")
    echo ""
    "$DIR/fetch_todos.sh"
    ;;
  "View Sprint")
    "$DIR/sprint-view.sh"
    ;;
  "Move Ticket")
    TICKET=$(gum input --prompt "Ticket: ")
    if [[ -n "$TICKET" ]]; then
      "$DIR/transition.sh" "$TICKET"
    fi
    ;;
  "Sprint Points")
    echo ""
    "$DIR/points.sh"
    ;;
  "Open Jira in Browser")
    if [[ -n "${JIRA_URL:-}" ]]; then
      open "$JIRA_URL"
    else
      gum style --foreground=1 "JIRA_URL not set"
    fi
    ;;
  "Quit")
    exit 0
    ;;
esac
